body {
    margin: 0;
    padding: 0;
    height: 100%;
    font-family: Poppins, sans-serif;
    background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)),
                url("../images/background.jpg") no-repeat center center;
    background-size: cover;
}

.login-section {
    display: flex;
    justify-content: center;
    align-items: center;
    height: 100vh;
    padding: 20px;
}

.login-box {
    background-color: rgba(0, 0, 0, 0.7);
    padding: 40px 30px;
    border-radius: 15px;
    width: 100%;
    max-width: 400px;
    text-align: center;
    color: #fff;
    box-shadow: 0 8px 30px rgba(0,0,0,0.5);
    transition: 1;
}

.login-box h1 {
    margin-bottom: 30px;
    font-size: 32px;
    color: #fff;
}

.login-box label {
    display: block;
    text-align: left;
    margin-bottom: 5px;
    font-weight: 500;
}

.login-box input {
    width: 100%;
    padding: 12px 15px;
    margin-bottom: 20px;
    border: none;
    border-radius: 20px;
    outline: none;
    font-size: 16px;
}

.login-box input:focus {
    border: 2px solid #c06b3e;
}

.login-buttons {
    display: flex;
    justify-content: space-between;
    gap: 10px;
}

.login-buttons .btn {
    display: inline-block;
    flex: 1;
    text-decoration: none;
    color: #fff;
    background-color: #c06b3e;
    padding: 12px 0;
    border-radius: 50px;
    font-weight: bold;
    transition: 0.3s;
}

.login-buttons .btn:hover {
    background-color: #e08d5a;
}

.note {
    margin-top: 15px;
    font-size: 12px;
    color: #ccc;
}

/* Responsive for smaller devices */
@media screen and (max-width: 480px) {
    .login-box {
        padding: 30px 20px;
    }

    .login-box h1 {
        font-size: 28px;
    }

    .login-buttons {
        flex-direction: column;
    }
}


